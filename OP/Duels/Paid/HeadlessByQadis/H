-- Drag toggleBtn
local _tbWasDragged = false
do
    local DRAG_THRESHOLD = 5
    local isDragging     = false
    local startInputPos  = Vector2.zero
    local startBtnX      = 0
    local startBtnY      = 0

    local function getAbsPos()
        local vp = workspace.CurrentCamera.ViewportSize
        return
            toggleBtn.Position.X.Scale * vp.X + toggleBtn.Position.X.Offset,
            toggleBtn.Position.Y.Scale * vp.Y + toggleBtn.Position.Y.Offset
    end

    local function onMove(pos)
        if not isDragging then return end
        local vp    = workspace.CurrentCamera.ViewportSize
        local delta = pos - startInputPos
        if delta.Magnitude >= DRAG_THRESHOLD then
            _tbWasDragged = true
        end
        if _tbWasDragged then
            local nx = math.clamp(startBtnX + delta.X, 0, vp.X - 50)
            local ny = math.clamp(startBtnY + delta.Y, 0, vp.Y - 50)
            toggleBtn.Position = UDim2.new(0, nx, 0, ny)
        end
    end

    local function onEnd()
        if not isDragging then return end
        isDragging = false
        if _tbWasDragged then
            saveConfig()
        end
    end

    toggleBtn.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        _tbWasDragged  = false
        isDragging     = true
        startInputPos  = Vector2.new(input.Position.X, input.Position.Y)
        startBtnX, startBtnY = getAbsPos()

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.Change then
                onMove(Vector2.new(input.Position.X, input.Position.Y))
            elseif input.UserInputState == Enum.UserInputState.End then
                onEnd()
            end
        end)
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not isDragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            onMove(Vector2.new(input.Position.X, input.Position.Y))
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            onEnd()
        end
    end)
end

