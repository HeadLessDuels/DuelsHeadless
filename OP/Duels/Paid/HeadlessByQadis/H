local function animateGradient(gradient)
    spawn(function()
        while gradient and gradient.Parent do
            for i = 0, 1, 0.01 do
                if not gradient or not gradient.Parent then break end
                gradient.Offset = Vector2.new(i, 0)
                wait(0.03)
            end
            for i = 1, 0, -0.01 do
                if not gradient or not gradient.Parent then break end
                gradient.Offset = Vector2.new(i, 0)
                wait(0.03)
            end
        end
    end)
end

local function animateBackgroundGradient(gradient)
    spawn(function()
        local rotation = 45
        while gradient and gradient.Parent do
            rotation = rotation + 1
            if rotation > 360 then rotation = 0 end
            gradient.Rotation = rotation
            wait(0.05)
        end
    end)
end

local function shakeFrame(frame)
    local originalPos = frame.Position
    for i = 1, 3 do
        frame.Position = originalPos + UDim2.new(0, 10, 0, 0)
        wait(0.05)
        frame.Position = originalPos - UDim2.new(0, 10, 0, 0)
        wait(0.05)
    end
    frame.Position = originalPos
end

