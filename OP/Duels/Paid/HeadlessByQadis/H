_notifSoundOff.Volume   = 0.35
_notifSoundOff.RollOffMaxDistance = 0
_notifSoundOff.Parent   = workspace

local _audioEnabled = false

local function _repositionNotifs()
    for idx, entry in ipairs(_activeNotifs) do
        local targetY = NOTIF_BASE_Y - (idx - 1) * (NOTIF_H + NOTIF_GAP)
        TweenService:Create(entry.frame,
            TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Position = UDim2.new(1, NOTIF_X, 1, targetY)}
        ):Play()
    end
end

local function showFeatureNotif(label, isOn)
    task.spawn(function()
        if not _audioEnabled then return end
        if isOn then
            _notifSound.PlaybackSpeed = 1.15
            _notifSound:Play()
        else
            _notifSoundOff.PlaybackSpeed = 0.88
            _notifSoundOff:Play()
        end
    end)
    local col    = isOn and Color3.fromRGB(180, 220, 190) or Color3.fromRGB(200, 120, 120)
    local suffix = isOn and "  ON" or "  OFF"
    local text   = label .. suffix
    local tw     = math.max(string.len(text) * 7 + 36, 120)
    local nf = Instance.new("Frame", sg)
    nf.Size                   = UDim2.new(0, 0, 0, NOTIF_H)
    nf.AnchorPoint            = Vector2.new(1, 1)
    nf.Position               = UDim2.new(1, NOTIF_X, 1, NOTIF_BASE_Y)
    nf.BackgroundColor3       = Color3.fromRGB(16, 16, 20)
    nf.BackgroundTransparency = 0.08
    nf.BorderSizePixel        = 0
    nf.ClipsDescendants       = true
    nf.ZIndex                 = 300
    Instance.new("UICorner", nf).CornerRadius = UDim.new(0, 8)
    local nStroke = Instance.new("UIStroke", nf)
    nStroke.Color        = col
    nStroke.Thickness    = 1.2
    nStroke.Transparency = 0.3
    local bar = Instance.new("Frame", nf)
    bar.Size             = UDim2.new(0, 3, 1, -8)
    bar.Position         = UDim2.new(0, 5, 0, 4)
    bar.BackgroundColor3 = col
    bar.BorderSizePixel  = 0
