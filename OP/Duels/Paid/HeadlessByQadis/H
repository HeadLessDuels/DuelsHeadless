    local function setupSpeedLabel(character)
        local head = character:WaitForChild("Head", 5)
        if not head then return end

        local old = head:FindFirstChild("SpeedBillboard")
        if old then old:Destroy() end

        local bb = Instance.new("BillboardGui", head)
        bb.Name         = "SpeedBillboard"
        bb.Size         = UDim2.new(0, 140, 0, 40)
        bb.StudsOffset  = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop  = true
        bb.ResetOnSpawn = false

        speedLbl = Instance.new("TextLabel", bb)

        speedLbl.AutoLocalize = false
        speedLbl.Size                = UDim2.new(1, 0, 0.5, 0)
        speedLbl.Position            = UDim2.new(0, 0, 0, 0)
        speedLbl.BackgroundTransparency = 1
        speedLbl.Text                = ""
        speedLbl.TextColor3          = Color3.fromRGB(200, 200, 215)
        speedLbl.Font                = Enum.Font.GothamBold
        speedLbl.TextScaled          = true
        speedLbl.TextStrokeTransparency = 0.1
        speedLbl.TextStrokeColor3    = Color3.fromRGB(0, 0, 0)
    end

    if Player.Character then
        task.spawn(function() setupSpeedLabel(Player.Character) end)
    end
    Player.CharacterAdded:Connect(function(c)
        task.wait(0.5)
        setupSpeedLabel(c)
    end)

    RunService.RenderStepped:Connect(function()
        if not speedLbl then return end
        local c = Player.Character if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end

        local vel = hrp.AssemblyLinearVelocity
        local spd = math.floor(math.sqrt(vel.X^2 + vel.Z^2))

        speedLbl.Text = "Speed: " .. spd
    end)
end

