-- Bat Aimbot
do
    local BAT_MOVE_SPEED   = 56.5
    local BAT_ENGAGE_RANGE = 20
    local BAT_LOOP_TIME    = 0.3
    local BAT_LOOK_DISTANCE = 50
    local lastEquipTick    = 0
    local lastUseTick      = 0
    local batToggled       = false

    local lookConn         = nil
    local attachment_bat   = nil
    local alignOri_bat     = nil

    local function equipBat()
        local c = Player.Character if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid") if not hum then return end
        local bat = Player.Backpack:FindFirstChild("Bat") or c:FindFirstChild("Bat")
        if bat then hum:EquipTool(bat) end
    end

    local function nearestTarget()
        local c = Player.Character if not c then return nil, math.huge end
        local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return nil, math.huge end
        local closest, minDist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player and plr.Character then
                local tHRP = plr.Character:FindFirstChild("HumanoidRootPart")
                local tHum = plr.Character:FindFirstChildOfClass("Humanoid")
                if tHRP and tHum and tHum.Health > 0 then
                    local d = (tHRP.Position - hrp.Position).Magnitude
                    if d < minDist then minDist = d; closest = tHRP end
                end
            end
        end
        return closest, minDist
    end

    local function closestLook()
        local c = Player.Character if not c then return nil end
        local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return nil end
        local nearest, shortest = nil, BAT_LOOK_DISTANCE
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local d = (hrp.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                if d < shortest then shortest = d; nearest = plr.Character.HumanoidRootPart end
            end
        end
        return nearest
    end

    local function startLookAt()
        local c = Player.Character if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
        local hum = c:FindFirstChildOfClass("Humanoid") if not hum then return end
        hum.AutoRotate = false
        attachment_bat = Instance.new("Attachment", hrp)
        alignOri_bat = Instance.new("AlignOrientation")
        alignOri_bat.Attachment0 = attachment_bat
        alignOri_bat.Mode = Enum.OrientationAlignmentMode.OneAttachment
        alignOri_bat.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        alignOri_bat.Responsiveness = 1000
        alignOri_bat.RigidityEnabled = true
        alignOri_bat.Parent = hrp
        lookConn = RunService.RenderStepped:Connect(function()
            if not hrp or not alignOri_bat then return end
            local target = closestLook()
            if not target then return end
            local lookPos = Vector3.new(target.Position.X, hrp.Position.Y, target.Position.Z)
            alignOri_bat.CFrame = CFrame.lookAt(hrp.Position, lookPos)
        end)
    end

    local function stopLookAt()
        if lookConn then lookConn:Disconnect(); lookConn = nil end
        if alignOri_bat then alignOri_bat:Destroy(); alignOri_bat = nil end
        if attachment_bat then attachment_bat:Destroy(); attachment_bat = nil end
        local c = Player.Character
        if c then
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum then hum.AutoRotate = true end
        end
    end

    local batHBConn = nil

    local function startBatAimbot()
        stopLookAt()
        batToggled = true
        local c = Player.Character if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
        startLookAt()
        if batHBConn then return end
        batHBConn = RunService.Heartbeat:Connect(function()
            if not Features.BatAimbot then return end
            local c2 = Player.Character if not c2 then return end
            local h   = c2:FindFirstChild("HumanoidRootPart") if not h then return end
            h.CanCollide = false
            local target, distance = nearestTarget()
            if not target then return end
            local moveDir = (target.Position - h.Position).Unit
            h.AssemblyLinearVelocity = moveDir * BAT_MOVE_SPEED
            if distance <= BAT_ENGAGE_RANGE then
                if tick() - lastEquipTick >= BAT_LOOP_TIME then
                    equipBat(); lastEquipTick = tick()
                end
                if tick() - lastUseTick >= BAT_LOOP_TIME then
                    local bat = c2:FindFirstChild("Bat")
                    if bat then bat:Activate() end
                    lastUseTick = tick()
                end
            end
        end)
    end

    local function stopBatAimbot()
        batToggled = false
        stopLookAt()
        if batHBConn then batHBConn:Disconnect(); batHBConn = nil end
        local c = Player.Character
        if c then
            local hrp = c:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
        end
    end

    makeToggle(scrollCombate, "Bat Aimbot", "BatAimbot", function(on)
        if on then startBatAimbot() else stopBatAimbot() end
    end)
    registerHud("Bat Aimbot", "BatAimbot")
end

