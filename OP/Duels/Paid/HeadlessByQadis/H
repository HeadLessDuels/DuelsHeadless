        local char = Player and Player.Character
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function DoDrop()
        if not dropRunning then return end
        local hum = GetHumanoid()
        local hrp = GetHRP()
        if hum and hrp then
            local pos = hrp.CFrame
            hum.UseJumpPower = true
            hum.JumpPower = 77
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.05)
            if not dropRunning then
                hum.JumpPower = 50
                return
            end
            hrp.CFrame = pos
            hum.JumpPower = 50
            task.wait(0.2)
            if not dropRunning then return end
            hum:ChangeState(Enum.HumanoidStateType.Landed)
            hrp.CFrame = pos
        end
    end

    local function EnableDrop()
        dropRunning = true
        task.spawn(function()
            while dropRunning do
                DoDrop()
                if dropRunning then task.wait(0.5) end
            end
        end)
    end

    local function DisableDrop()
