                {BackgroundColor3=Color3.fromRGB(55,55,65)}):Play()
            pillStroke.Color = Color3.fromRGB(200, 200, 210)
            TweenService:Create(circle, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Position=UDim2.new(1,-(circleD+2),0.5,-circleD/2),
                 BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
        else
            TweenService:Create(pill, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {BackgroundColor3=Color3.fromRGB(38,38,46)}):Play()
            pillStroke.Color = Color3.fromRGB(55, 55, 65)
            TweenService:Create(circle, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Position=UDim2.new(0,2,0.5,-circleD/2),
                 BackgroundColor3=Color3.fromRGB(120,120,130)}):Play()
        end
    end

    local hitbox = Instance.new("TextButton", frame)
    hitbox.Size               = UDim2.new(1, 0, 1, 0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text               = ""
    hitbox.ZIndex             = 6
    hitbox.MouseEnter:Connect(function()
        TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3=_C_ROW2}):Play()
    end)
    hitbox.MouseLeave:Connect(function()
        TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3=_C_ROW}):Play()
    end)

    hitbox.MouseButton1Click:Connect(function()
        isOn = not isOn
        updateVisual()
        if Features[featureName] ~= nil then
            Features[featureName] = isOn
        end
        spawnBubbles(frame, isOn)
        showFeatureNotif(labelText, isOn)
        if onToggle then
            onToggle(isOn)
        end
    end)

    local function setV(state)
        isOn = state
        if Features[featureName] ~= nil then
            Features[featureName] = isOn
        end
        updateVisual()
    end
    local function getV() return isOn end

    FeatureToggles[featureName] = function()
        isOn = not isOn
        if Features[featureName] ~= nil then
            Features[featureName] = isOn
        end
        updateVisual()
        spawnBubbles(frame, isOn)
        showFeatureNotif(labelText, isOn)
        if onToggle then
            onToggle(isOn)
        end
    end

    return hitbox, setV, getV, featureName
end

local function buildHud()
    if hudPanel then hudPanel:Destroy() end

    -- Secciones rediseñadas: cada opción es un botón flotante independiente
    local hudFeats = {
        { feat = "BatAimbot",   label = "Bat Aimbot"   },
        { feat = "RightSteal",  label = "Base 2 Steal" },
        { feat = "LeftSteal",   label = "Base 1 Steal" },
        { feat = "RagdollTP",   label = "Ragdoll TP"   },
    }

    local BTN_W  = 130
    local BTN_H  = 36
    local GAP    = 8
    local startX = VP.X - BTN_W - 12
    local startY = VP.Y * 0.18

    hudPanel = Instance.new("Frame", sg)
    hudPanel.Name                   = "HudPanel"
    hudPanel.Size                   = UDim2.new(1, 0, 1, 0)
    hudPanel.BackgroundTransparency = 1
    hudPanel.BorderSizePixel        = 0
    hudPanel.ZIndex                 = 150
    hudPanel.Active                 = false  -- no bloquear clicks del juego

    for i, entry in ipairs(hudFeats) do
        local isOn = Features[entry.feat] or false
        local yPos = startY + (i - 1) * (BTN_H + GAP)

        -- Usar posición guardada si existe
        local savedPos = HudPositions[entry.feat]
        local posX = savedPos and savedPos.x or startX
        local posY = savedPos and savedPos.y or yPos

        local btn = Instance.new("TextButton", hudPanel)
        btn.Size             = UDim2.new(0, BTN_W, 0, BTN_H)
        btn.Position         = UDim2.new(0, posX, 0, posY)
        btn.BackgroundColor3 = isOn and Color3.fromRGB(38, 32, 65) or Color3.fromRGB(16, 16, 22)
        btn.BorderSizePixel  = 0
        btn.Text             = ""
        btn.ZIndex           = 151
        btn.AutoButtonColor  = false
        btn.Active           = true
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

        local btnStroke = Instance.new("UIStroke", btn)
        btnStroke.Thickness    = 1.5
        btnStroke.Color        = isOn and Color3.fromRGB(120, 80, 255) or Color3.fromRGB(50, 50, 62)
        btnStroke.Transparency = 0

        -- Punto indicador
        local dot = Instance.new("Frame", btn)
        dot.Size             = UDim2.new(0, 9, 0, 9)
        dot.Position         = UDim2.new(0, 10, 0.5, -4.5)
        dot.BackgroundColor3 = isOn and Color3.fromRGB(120, 80, 255) or Color3.fromRGB(60, 60, 72)
        dot.BorderSizePixel  = 0
        dot.ZIndex           = 152
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

        -- Glow del dot cuando ON
        local dotGlow = Instance.new("UIStroke", dot)
        dotGlow.Thickness    = 2
        dotGlow.Color        = Color3.fromRGB(160, 100, 255)
        dotGlow.Transparency = isOn and 0.3 or 1

        local lbl = Instance.new("TextLabel", btn)
        lbl.Size               = UDim2.new(1, -28, 1, 0)
        lbl.Position           = UDim2.new(0, 26, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text               = entry.label
        lbl.Font               = Enum.Font.GothamBold
        lbl.TextSize           = 12
        lbl.TextColor3         = isOn and Color3.fromRGB(225, 218, 255) or Color3.fromRGB(120, 120, 138)
        lbl.TextXAlignment     = Enum.TextXAlignment.Left
        lbl.ZIndex             = 152

        -- Arrastre individual de cada botón (Mouse + Touch)
        do
            local drag      = false
            local moved     = false
            local ds        = nil
            local sp        = nil
            local THRESHOLD = 8

            local function onInputBegan(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    drag  = true
                    moved = false
                    ds    = inp.Position
                    sp    = btn.Position
                end
            end

            local function onInputChanged(inp)
                if not drag then return end
                if inp.UserInputType ~= Enum.UserInputType.MouseMovement
                and inp.UserInputType ~= Enum.UserInputType.Touch then return end
                local d = inp.Position - ds
                if not moved and (math.abs(d.X) > THRESHOLD or math.abs(d.Y) > THRESHOLD) then
                    moved = true
                end
                if moved then
                    btn.Position = UDim2.new(0,
                        math.clamp(sp.X.Offset + d.X, 0, VP.X - BTN_W),
                        0,
                        math.clamp(sp.Y.Offset + d.Y, 0, VP.Y - BTN_H)
                    )
                end
            end

            local function onInputEnded(inp)
                if not drag then return end
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    if not moved then
                        if FeatureToggles[entry.feat] then FeatureToggles[entry.feat]() end
                    else
                        -- Guardar posición nueva
                        HudPositions[entry.feat] = { x = btn.Position.X.Offset, y = btn.Position.Y.Offset }
                    end
                    drag  = false
                    moved = false
                end
            end

            -- InputBegan en el botón para iniciar drag/tap
            btn.InputBegan:Connect(onInputBegan)
            -- InputChanged e InputEnded globales, pero solo actúan si drag == true (este botón fue presionado)
            UserInputService.InputChanged:Connect(onInputChanged)
            UserInputService.InputEnded:Connect(onInputEnded)
        end

        local function refreshHudBtn()
            local on = Features[entry.feat] or false
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3 = on and Color3.fromRGB(38, 32, 65) or Color3.fromRGB(16, 16, 22)
            }):Play()
            btnStroke.Color      = on and Color3.fromRGB(120, 80, 255) or Color3.fromRGB(50, 50, 62)
            dot.BackgroundColor3 = on and Color3.fromRGB(120, 80, 255) or Color3.fromRGB(60, 60, 72)
            dotGlow.Transparency = on and 0.3 or 1
            lbl.TextColor3       = on and Color3.fromRGB(225, 218, 255) or Color3.fromRGB(120, 120, 138)
        end

        local origToggle = FeatureToggles[entry.feat]
        FeatureToggles[entry.feat] = function()
            if origToggle then origToggle() end
            refreshHudBtn()
        end

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(28, 24, 46)}):Play()
        end)
        btn.MouseLeave:Connect(function()
            local on = Features[entry.feat] or false
            TweenService:Create(btn, TweenInfo.new(0.1), {
                BackgroundColor3 = on and Color3.fromRGB(38, 32, 65) or Color3.fromRGB(16, 16, 22)
            }):Play()
        end)
    end
end

