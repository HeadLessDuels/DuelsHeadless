        local stealFuncs = _G["_SilentHub_StealFuncs"]
        if not stealFuncs then return end
        autoplayActive = not autoplayActive
        if autoplayActive then
            if autoplaySelected == "RightSteal" then stealFuncs.startRight()
            else stealFuncs.startLeft() end
