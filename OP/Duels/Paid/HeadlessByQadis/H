    local apDragging   = false
    local apWasDragged = false
    local DRAG_THRESH  = 6
    _G["_SilentHub_ApWasDragged"] = false

    local function headerHitTest(pos)
        local ap = apPanel.AbsolutePosition
        return pos.X >= ap.X and pos.X <= ap.X + PW
           and pos.Y >= ap.Y and pos.Y <= ap.Y + ROW_H
    end

    local apStartMouseX = 0
    local apStartMouseY = 0
    local apStartPosX   = 0
    local apStartPosY   = 0

    local function doDragBegin(pos)
        if apDragging then return end
        apDragging   = true
        apWasDragged = false
        _G["_SilentHub_ApWasDragged"] = false
        apStartMouseX = pos.X
        apStartMouseY = pos.Y
        apStartPosX   = apPanel.Position.X.Offset
        apStartPosY   = apPanel.Position.Y.Offset
    end

    local function doDragMove(pos)
        if not apDragging then return end
        local dx = pos.X - apStartMouseX
        local dy = pos.Y - apStartMouseY
        if not apWasDragged and (math.abs(dx) > DRAG_THRESH or math.abs(dy) > DRAG_THRESH) then
            apWasDragged = true
            _G["_SilentHub_ApWasDragged"] = true
        end
        if apWasDragged then
            local vp = workspace.CurrentCamera.ViewportSize
            local nx = math.clamp(apStartPosX + dx, 0, vp.X - PW)
            local ny = math.clamp(apStartPosY + dy, 0, vp.Y - ROW_H)
            apPanel.Position = UDim2.new(0, nx, 0, ny)
        end
    end

    local function doDragEnd()
        if not apDragging then return end
        apDragging = false
        if apWasDragged then saveConfig() end
        task.delay(0.1, function()
            apWasDragged = false
            _G["_SilentHub_ApWasDragged"] = false
        end)
    end

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        local pos = Vector2.new(input.Position.X, input.Position.Y)
        if headerHitTest(pos) then doDragBegin(pos) end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and apDragging then
            doDragMove(Vector2.new(input.Position.X, input.Position.Y))
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then doDragEnd() end
    end)
    UserInputService.TouchStarted:Connect(function(input)
        local pos = Vector2.new(input.Position.X, input.Position.Y)
        if not headerHitTest(pos) then return end
        doDragBegin(pos)
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.Change then
                doDragMove(Vector2.new(input.Position.X, input.Position.Y))
            elseif input.UserInputState == Enum.UserInputState.End then
                doDragEnd()
            end
        end)
    end)

