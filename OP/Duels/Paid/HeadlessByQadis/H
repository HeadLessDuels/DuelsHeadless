        bindBtn.BorderSizePixel  = 0
        bindBtn.ZIndex           = 7
        bindBtn.AutoButtonColor  = false
        bindBtn.ClipsDescendants = true
        Instance.new("UICorner", bindBtn).CornerRadius = UDim.new(0, 4*guiScale)
