                if state ~= isOn then isOn = state; updateBtn() end
            end)
        end

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(30,30,38)}):Play()
        end)
        btn.MouseLeave:Connect(function()
            if not isOn then TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(22,22,28)}):Play() end
        end)
    end
end

-- ==================== MÓVIL: BOTONES TÁCTILES AUTO RIGHT / AUTO LEFT ====================
if isMobile then
    local MB_W = math.floor(110 * guiScale)
    local MB_H = math.floor(48 * guiScale)
    local MB_PAD = math.floor(10 * guiScale)

    local function makeMobileStealBtn(label, xAnchor, xOffset, startFn, stopFn)
        local btn = Instance.new("TextButton", sg)
        btn.AutoLocalize = false
        btn.Size = UDim2.new(0, MB_W, 0, MB_H)
        btn.AnchorPoint = Vector2.new(xAnchor, 1)
        btn.Position = UDim2.new(xAnchor, xOffset, 1, -(MB_PAD + 60))
        btn.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
        btn.BackgroundTransparency = 0.08
        btn.TextColor3 = C_TEXT
        btn.Font = Enum.Font.GothamBlack
        btn.TextSize = math.floor(13 * guiScale)
        btn.Text = label
        btn.BorderSizePixel = 0
        btn.ZIndex = 200
        btn.AutoButtonColor = false
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10*guiScale)

        local bStroke = Instance.new("UIStroke", btn)
        bStroke.Color = Color3.fromRGB(70, 70, 88)
        bStroke.Thickness = 1.2
        bStroke.Transparency = 0.3
        addAccent(bStroke, "Color")

        local holding = false
        btn.InputBegan:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.Touch then return end
            holding = true
            TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3=Color3.fromRGB(42,42,55)}):Play()
            bStroke.Transparency = 0
            local sf = _G["_SilentHub_StealFuncs"]
            if sf then startFn(sf) end
        end)
        btn.InputEnded:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.Touch or not holding then return end
            holding = false
            TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3=Color3.fromRGB(22,22,30)}):Play()
            bStroke.Transparency = 0.3
            local sf = _G["_SilentHub_StealFuncs"]
            if sf then stopFn(sf) end
        end)
    end

    task.defer(function()
        makeMobileStealBtn("◀  Auto Left",  0,  MB_PAD, function(sf) sf.startLeft()  end, function(sf) sf.stopLeft()  end)
        makeMobileStealBtn("Auto Right  ▶", 1, -MB_PAD, function(sf) sf.startRight() end, function(sf) sf.stopRight() end)

        local ap = _G["_SilentHub_AutoplayPanel"]
        if ap then
            for _, ch in ipairs(ap:GetDescendants()) do
                if ch:IsA("TextLabel") and ch.Text == "BIND KEY" then ch.Visible = false end
                if ch:IsA("TextButton") and ch.Text == "BIND" then ch.Visible = false end
            end
        end
    end)
end
