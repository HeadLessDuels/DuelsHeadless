-- ==================== ANIMACIÓN DE NIEVE ====================
local function startSnow(parent, w, h, zIdx, count)
    count = count or 18
    local snowflakes = {}

    local function makeFlake()
        local flake = Instance.new("Frame", parent)
        local size  = math.random(2, 5)
        flake.Size                   = UDim2.new(0, size, 0, size)
        flake.BackgroundColor3       = Color3.fromRGB(210, 220, 255)
        flake.BackgroundTransparency = math.random(0, 40) / 100
        flake.BorderSizePixel        = 0
        flake.ZIndex                 = zIdx
        flake.Position               = UDim2.new(0, math.random(0, math.max(1, w - size)), 0, -size)
        Instance.new("UICorner", flake).CornerRadius = UDim.new(1, 0)
        return flake
    end

    -- Crear copos iniciales en posiciones aleatorias
    for _ = 1, count do
        local flake = makeFlake()
        -- Empezar en posición aleatoria en Y para que no comiencen todos juntos
        flake.Position = UDim2.new(0,
            math.random(0, math.max(1, w - 5)),
            0,
            math.random(-10, h)
        )
        table.insert(snowflakes, {
            frame   = flake,
            speed   = math.random(40, 100) / 100,
            drift   = (math.random(-30, 30)) / 100,
            y       = flake.Position.Y.Offset,
            x       = flake.Position.X.Offset,
        })
    end

    RunService.Heartbeat:Connect(function(dt)
        if not parent or not parent.Parent then return end
        for _, s in ipairs(snowflakes) do
            if not s.frame or not s.frame.Parent then continue end
            s.y = s.y + s.speed * dt * 60
            s.x = s.x + s.drift * dt * 10
            -- Reiniciar cuando sale por abajo
            if s.y > h + 6 then
                s.y = -6
                s.x = math.random(0, math.max(1, w - 5))
            end
            -- Rebotar en los lados
            if s.x < 0 then s.x = 0; s.drift = math.abs(s.drift)
            elseif s.x > w - 4 then s.x = w - 4; s.drift = -math.abs(s.drift) end
            s.frame.Position = UDim2.new(0, math.floor(s.x), 0, math.floor(s.y))
        end
    end)
end

