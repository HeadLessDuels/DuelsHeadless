local function spawnBubbles(frame, isOn)
    local accentCol = isOn and Color3.fromRGB(180, 180, 195) or Color3.fromRGB(100, 100, 110)
    local glowCol   = isOn and Color3.fromRGB(220, 220, 230) or Color3.fromRGB(150, 150, 160)
    local count = 6

    local clipper = Instance.new("Frame", frame)
    clipper.Size                   = UDim2.new(1, 0, 1, 0)
    clipper.Position               = UDim2.new(0, 0, 0, 0)
    clipper.BackgroundTransparency = 1
    clipper.BorderSizePixel        = 0
    clipper.ClipsDescendants       = true
    clipper.ZIndex                 = 19

    local fW = frame.AbsoluteSize.X
    local fH = frame.AbsoluteSize.Y
    local maxSize = math.min(fH * 0.82, 20)
    local minSize = math.max(maxSize * 0.5, 6)

    local pending = count
    for i = 1, count do
        local size = minSize + math.random() * (maxSize - minSize)
        local x = size/2 + math.random() * math.max(fW - size, 1)
        local y = size/2 + math.random() * math.max(fH - size, 1)

        local bubble = Instance.new("Frame", clipper)
        bubble.Size                   = UDim2.new(0, 0, 0, 0)
        bubble.AnchorPoint            = Vector2.new(0.5, 0.5)
        bubble.Position               = UDim2.new(0, x, 0, y)
        bubble.BackgroundColor3       = accentCol
        bubble.BackgroundTransparency = 0.25
        bubble.BorderSizePixel        = 0
        bubble.ZIndex                 = 20
        bubble.ClipsDescendants       = false
        Instance.new("UICorner", bubble).CornerRadius = UDim.new(1, 0)
        local stroke = Instance.new("UIStroke", bubble)
        stroke.Color        = glowCol
        stroke.Thickness    = 1
        stroke.Transparency = 0.5

        task.delay((i-1) * 0.04, function()
            if not bubble.Parent then pending -= 1; if pending <= 0 then clipper:Destroy() end; return end
            local duration = 0.42 + math.random() * 0.18

            TweenService:Create(bubble,
                TweenInfo.new(duration * 0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                {Size = UDim2.new(0, size, 0, size), BackgroundTransparency = 0.45}
            ):Play()
            task.delay(duration * 0.6, function()
                if not bubble.Parent then pending -= 1; if pending <= 0 then clipper:Destroy() end; return end
                local size2 = math.min(size * 1.35, maxSize * 1.35)
                TweenService:Create(bubble,
                    TweenInfo.new(duration * 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    {Size = UDim2.new(0, size2, 0, size2), BackgroundTransparency = 1}
                ):Play()
                TweenService:Create(stroke, TweenInfo.new(duration * 0.4), {Transparency = 1}):Play()
                task.delay(duration * 0.4, function()
                    if bubble then bubble:Destroy() end
                    pending -= 1
                    if pending <= 0 and clipper and clipper.Parent then clipper:Destroy() end
                end)
            end)
        end)
    end
end

