-- Infinity Jump
do
    local infJumpEnabled = false
    local infJumpConn    = nil

    local function startInfJump()
        if infJumpConn then infJumpConn:Disconnect() infJumpConn = nil end
        infJumpConn = RunService.Heartbeat:Connect(function()
            if not infJumpEnabled then return end
            pcall(function()
                local c = Player.Character if not c then return end
                local hum = c:FindFirstChildOfClass("Humanoid") if not hum then return end
                local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
                local onGround = hum.FloorMaterial ~= Enum.Material.Air
                if hum.Jump == true and not onGround then
                    hrp.AssemblyLinearVelocity = Vector3.new(
                        hrp.AssemblyLinearVelocity.X,
                        Values.HOP_POWER,
                        hrp.AssemblyLinearVelocity.Z
                    )
                end
            end)
        end)
    end

    local function stopInfJump()
        if infJumpConn then infJumpConn:Disconnect() infJumpConn = nil end
    end

    local jumpConn = nil
    local function connectJumpEvent()
        if jumpConn then jumpConn:Disconnect() jumpConn = nil end
        local c = Player.Character if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid") if not hum then return end
        jumpConn = hum:GetPropertyChangedSignal("Jump"):Connect(function()
            if not infJumpEnabled then return end
            if not hum.Jump then return end
            pcall(function()
                local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
                task.wait()
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X,
                    Values.HOP_POWER,
                    hrp.AssemblyLinearVelocity.Z
                )
            end)
        end)
    end

    if Player.Character then connectJumpEvent() end
    Player.CharacterAdded:Connect(function(c)
        task.wait(0.5)
        connectJumpEvent()
    end)

    makeToggle(scrollMovimiento, "Inf Jump", "GalaxyMode", function(on)
        infJumpEnabled = on
        if on then startInfJump(); connectJumpEvent()
        else stopInfJump() end
    end)
end

