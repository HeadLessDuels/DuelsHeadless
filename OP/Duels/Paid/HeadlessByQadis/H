    _repositionNotifs()
    TweenService:Create(nf, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, tw, 0, NOTIF_H)}):Play()
    task.delay(1.8, function()
        if not nf or not nf.Parent then return end
        TweenService:Create(nf, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
