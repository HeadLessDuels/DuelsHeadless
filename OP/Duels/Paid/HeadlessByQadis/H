            local key = FeatureKeybinds[featureName]
            if key then
                local name = tostring(key):match("KeyCode%.(.+)") or tostring(key)
                bindBtn.Text             = name
                bindBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 34)
                bindBtn.TextColor3       = _C_TEXT2
                bStroke.Color            = Color3.fromRGB(60, 60, 70)
            else
                bindBtn.Text             = "BIND"
                bindBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
                bindBtn.TextColor3       = _C_SUB2
                bStroke.Color            = Color3.fromRGB(42, 42, 50)
            end
        end

        FeatureBindBtns[featureName] = refreshBindVisual

        local function stopListening()
            listeningBindBtn = nil
            listeningFeature = nil
            refreshBindVisual()
        end

        bindBtn.MouseButton1Click:Connect(function()
            if listeningBindBtn == bindBtn then
                stopListening(); return
            end
            if listeningBindBtn then
                listeningBindBtn.Text             = "BIND"
                listeningBindBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
                listeningBindBtn.TextColor3       = _C_SUB2
            end
            listeningBindBtn = bindBtn
            listeningFeature = featureName
            bindBtn.Text             = "..."
            bindBtn.BackgroundColor3 = Color3.fromRGB(36, 36, 44)
            bindBtn.TextColor3       = Color3.fromRGB(200, 200, 210)
            bStroke.Color            = Color3.fromRGB(130, 130, 150)
        end)
        bindBtn.MouseEnter:Connect(function()
            if listeningBindBtn ~= bindBtn then
                TweenService:Create(bindBtn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(28,28,34)}):Play()
            end
        end)
        bindBtn.MouseLeave:Connect(function()
            if listeningBindBtn ~= bindBtn then
                TweenService:Create(bindBtn, TweenInfo.new(0.1), {BackgroundColor3=Color3.fromRGB(22,22,26)}):Play()
            end
        end)
    end

    local pillW   = isMobile and 46*guiScale or 36
    local pillH   = isMobile and 26*guiScale or 20
    local circleD = pillH - 4

    local pill = Instance.new("Frame", frame)
