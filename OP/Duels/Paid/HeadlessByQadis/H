local SAVE_FILE = "SilentHub_Config.txt"

local function saveConfig()
    local lines = {}
    for k, v in pairs(Features) do
        table.insert(lines, "F:" .. k .. "=" .. tostring(v))
    end
    for k, v in pairs(Values) do
        table.insert(lines, "V:" .. k .. "=" .. tostring(v))
    end
    for k, v in pairs(FeatureKeybinds) do
        local name = tostring(v):match("KeyCode%.(.+)") or tostring(v)
        if name and name ~= "" then
            table.insert(lines, "K:" .. k .. "=" .. name)
        end
    end
    if toggleBtn then
        local vp = workspace.CurrentCamera.ViewportSize
        local bx = math.floor(toggleBtn.Position.X.Scale * vp.X + toggleBtn.Position.X.Offset)
        local by = math.floor(toggleBtn.Position.Y.Scale * vp.Y + toggleBtn.Position.Y.Offset)
        table.insert(lines, "P:toggleBtn=" .. bx .. "," .. by)
    end
    if _G["_SilentHub_AutoplayPanel"] then
        local ap = _G["_SilentHub_AutoplayPanel"]
        if ap and ap.Parent then
            local vp = workspace.CurrentCamera.ViewportSize
            local ax = math.floor(ap.Position.X.Scale * vp.X + ap.Position.X.Offset)
            local ay = math.floor(ap.Position.Y.Scale * vp.Y + ap.Position.Y.Offset)
            table.insert(lines, "P:autoplayPanel=" .. ax .. "," .. ay)
        end
    end
    if _G["_SilentHub_AutoplayKeybind"] then
        local kname = tostring(_G["_SilentHub_AutoplayKeybind"]):match("KeyCode%.(.+)") or tostring(_G["_SilentHub_AutoplayKeybind"])
        if kname and kname ~= "" and kname ~= "Unknown" then
            table.insert(lines, "P:autoplayKey=" .. kname)
        end
    end
    local data = table.concat(lines, "\n")
    local ok = pcall(writefile, SAVE_FILE, data)
    if not ok then
        _G["_SilentHub_Data"] = data
    else
        _G["_SilentHub_Data"] = data
    end
end

local function loadConfig()
    local data = nil
    local ok, result = pcall(readfile, SAVE_FILE)
    if ok and result and #result > 0 then
        data = result
    elseif _G["_SilentHub_Data"] and #tostring(_G["_SilentHub_Data"]) > 0 then
        data = _G["_SilentHub_Data"]
    end
    if not data then return end

    local pendingKeybinds = {}
    for line in data:gmatch("[^\n]+") do
        local prefix = line:sub(1, 2)
        local rest   = line:sub(3)
        local k, v   = rest:match("([^=]+)=(.+)")
        if k and v then
            if prefix == "F:" then
                if Features[k] ~= nil then Features[k] = (v == "true") end
            elseif prefix == "V:" then
                if Values[k] ~= nil then
                    local num = tonumber(v)
                    if num then Values[k] = num end
                end
            elseif prefix == "K:" then
                pendingKeybinds[k] = v
            elseif prefix == "P:" then
                if k == "toggleBtn" then
                    local bx, by = v:match("(-?%d+),(-?%d+)")
                    if bx and by then
                        _G["_SilentHub_BtnPos"] = {x = tonumber(bx), y = tonumber(by)}
                    end
                elseif k == "autoplayPanel" then
                    local ax, ay = v:match("(-?%d+),(-?%d+)")
                    if ax and ay then
                        _G["_SilentHub_AutoplayPanelPos"] = {x = tonumber(ax), y = tonumber(ay)}
                    end
                elseif k == "autoplayKey" then
                    local ok2, kc = pcall(function() return Enum.KeyCode[v] end)
                    if ok2 and kc then
                        _G["_SilentHub_AutoplayKeybindPending"] = kc
                    end
                end
            end
        end
    end
    _G["_SilentHub_PendingKeybinds"] = pendingKeybinds
end

